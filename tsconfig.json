{
    "include": [
        "src/scripts/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "src/scripts/app/*",
        "src/scripts/dist/*",
        "src/scripts/lib/*",
        "src/scripts/types/*",
        "**/*.js",
        "**/*.d.ts",
    ],

    // Visit https://aka.ms/tsconfig to read more about this file
    "compilerOptions": {
        // Base Options recommended for all projects
        "esModuleInterop": true,
        "skipLibCheck": true,
        "target": "es2022",
        "allowJs": true,
        "checkJs": false,
        "resolveJsonModule": true,
        "moduleDetection": "force",
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "declaration": true,
        "declarationDir": "./src/scripts/types",
        // Transpile our TypeScript code to JavaScript
        "module": "esnext",
        // Include the DOM types
        "lib": [
            "es2022",
            "dom",
            "dom.iterable"
        ],
        "rootDir": "./src/scripts/ts",
        "outDir": "./src/scripts/dist"
    },
}